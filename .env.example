# Copy to .env and fill in values:
#   cp .env.example .env
#
# The CLI loads .env automatically (existing environment variables win).
# NEOHUB_HOST is optional — if unset, the CLI auto-discovers when exactly
# one NeoHub responds on the LAN.

# Optional if a single hub is discoverable on the LAN
# NEOHUB_HOST=192.168.0.19

# Required for live-data / system / cmd
NEOHUB_TOKEN=your-api-token

# Optional (default 4243)
# NEOHUB_PORT=4243

# Optional logging (CLI)
# NEOHUB_VERBOSE=1
# NEOHUB_DEBUG=1
